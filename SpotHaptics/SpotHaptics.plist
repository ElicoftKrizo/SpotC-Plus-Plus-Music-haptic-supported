<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  SpotHaptics.plist
  Tells MobileSubstrate / ElleKit / Substitute to inject SpotHaptics.dylib
  ONLY into the Spotify app bundle (com.spotify.client).
  
  Place this file alongside SpotHaptics.dylib at:
    /Library/MobileSubstrate/DynamicLibraries/SpotHaptics.plist
-->
<plist version="1.0">
<dict>
  <key>Filter</key>
  <dict>
    <!-- Restrict injection to Spotify only -->
    <key>Bundles</key>
    <array>
      <string>com.spotify.client</string>
    </array>
    <!-- Require iOS 13+ for CoreHaptics support -->
    <key>CoreFoundationVersion</key>
    <array>
      <real>1665</real>   <!-- iOS 13.0 -->
    </array>
  </dict>
</dict>
</plist>
